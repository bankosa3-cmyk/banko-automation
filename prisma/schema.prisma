generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RewardStatus {
  active
  redeemed
  expired
  cancelled
}

enum RewardFulfillmentType {
  coupon
  wallet
}

enum CouponStatus {
  active
  redeemed
  expired
  cancelled
}

enum WebhookEventStatus {
  received
  processed
  failed
  ignored
}

enum NotificationStatus {
  pending
  sent
  failed
}

model Customer {
  id             String           @id @default(uuid())
  zidCustomerId  String           @unique
  email          String?
  phone          String?
  name           String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  orders         Order[]
  rewards        CustomerReward[]
  notifications  NotificationLog[]
}

model Order {
  id           String   @id @default(uuid())
  zidOrderId   String   @unique
  customerId   String
  status       String
  totalAmount  Decimal  @db.Decimal(10, 2)
  completedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  customer     Customer @relation(fields: [customerId], references: [id])
  rewards      CustomerReward[]
}

model CustomerReward {
  id                  String                @id @default(uuid())
  customerId          String
  sourceOrderId       String
  amount              Decimal               @db.Decimal(10, 2)
  minimumOrderAmount  Decimal               @db.Decimal(10, 2)
  expiresAt           DateTime
  status              RewardStatus          @default(active)
  fulfillmentType     RewardFulfillmentType @default(coupon)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  customer            Customer              @relation(fields: [customerId], references: [id])
  sourceOrder         Order                 @relation(fields: [sourceOrderId], references: [id])
  coupon              Coupon?
}

model Coupon {
  id                  String       @id @default(uuid())
  rewardId            String       @unique
  code                String       @unique
  zidCouponId          String?
  amount              Decimal      @db.Decimal(10, 2)
  minimumOrderAmount  Decimal      @db.Decimal(10, 2)
  usageLimit          Int          @default(1)
  expiresAt           DateTime
  status              CouponStatus @default(active)
  createdAt           DateTime     @default(now())
  updatedAt           DateTime     @updatedAt

  reward              CustomerReward @relation(fields: [rewardId], references: [id])
}

model WebhookEvent {
  id               String             @id @default(uuid())
  provider         String
  eventType        String
  externalEventId  String?            @unique
  payload          Json
  status           WebhookEventStatus @default(received)
  receivedAt       DateTime           @default(now())
  processedAt      DateTime?
  errorMessage     String?
}

model NotificationLog {
  id          String             @id @default(uuid())
  customerId  String
  rewardId    String?
  channel     String
  status      NotificationStatus @default(pending)
  message     String?
  sentAt      DateTime?
  createdAt   DateTime           @default(now())

  customer    Customer           @relation(fields: [customerId], references: [id])
}

model AutomationLog {
  id        String   @id @default(uuid())
  type      String
  message   String
  metadata  Json?
  createdAt DateTime @default(now())
}
model ZidStoreToken {
  id                 String   @id @default(uuid())
  storeId            String   @unique
  authorizationToken String   @db.Text
  managerToken       String   @db.Text
  refreshToken       String?  @db.Text
  tokenType          String?
  expiresAt          DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}